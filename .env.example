# Copy to `.env.local` for Next.js. Never commit `.env` or `.env.local`.

# Convex deployment URL (from `npx convex dev` or the Convex dashboard).
NEXT_PUBLIC_CONVEX_URL=

# For Convex functions that call Gemini (`convex/aiRuntime.ts`), set this in the
# Convex dashboard under Deployment → Settings → Environment Variables, or in
# `.env.local` when using `npx convex dev` with local env sync.

GEMINI_API_KEY=
