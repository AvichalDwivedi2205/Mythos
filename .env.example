# Copy to `.env.local` for Next.js. Never commit `.env` or `.env.local`.

# Convex deployment URL (from `npx convex dev` or the Convex dashboard).
NEXT_PUBLIC_CONVEX_URL=

# For Convex functions that call the LLM (`convex/aiRuntime.ts`, `convex/lib/llmProvider.ts`),
# set these in the Convex dashboard under Deployment → Settings → Environment Variables,
# or in `.env.local` when using `npx convex dev` with local env sync.

# `gemini` (default) = direct Google Generative AI. `openrouter` = OpenRouter OpenAI-compatible API.
# LLM_PROVIDER=gemini

# Required when LLM_PROVIDER is gemini (default)
GEMINI_API_KEY=
# Optional override; default is gemini-3.1-flash-lite-preview
# GEMINI_MODEL=

# Required when LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# Default model on OpenRouter: google/gemini-3.1-flash-lite-preview
# OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
# Optional attribution headers for OpenRouter rankings
# OPENROUTER_HTTP_REFERER=https://yoursite.example
# OPENROUTER_APP_TITLE=Mythos
